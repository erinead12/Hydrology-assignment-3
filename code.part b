import numpy as np
import matplotlib.pyplot as plt

# Data
h0, hL = 4.0, 2.0
L1, L2 = 500.0, 500.0
L = L1 + L2
K1, K2 = 10.0, 200.0  # Original Case

h_int = ((K1 * h0 / L1) + (K2 * hL / L2)) / ((K1 / L1) + (K2 / L2))

x = np.linspace(0, L, 100)
h_x = np.piecewise(x, [x <= L1, x > L1],
                  [lambda x: h0 + (h_int - h0) / L1 * x, 
                   lambda x: h_int + (hL - h_int) / L2 * (x - L1)])

plt.figure(figsize=(8, 5))
plt.plot(x, h_x, 'b-', label='Head Profile')
plt.axvline(x=L1, color='red', linestyle='--', label='Interface')
plt.xlabel('Distance x (m)'); plt.ylabel('Head (m)')
plt.title('Question 3: Steady-State Head Profile'); plt.grid(True, alpha=0.3); plt.legend()
plt.savefig('groundwater_profile.png')
plt.show()
print(f"Interface Head: {h_int:.3f} m")

